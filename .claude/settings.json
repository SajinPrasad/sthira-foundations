{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"if (String(process.env.CLAUDE_TOOL_INPUT).startsWith('npm i')) console.log('⚠️ WAIT: Double check package versions!');\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require('child_process').execSync('npx prettier --write \\\"' + process.env.CLAUDE_TOOL_INPUT_FILE_PATH + '\\\"', { stdio: 'inherit' })\""
          }
        ]
      }
    ]
  }
}